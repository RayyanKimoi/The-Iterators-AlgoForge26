# SPORS Mobile Environment Template
# Copy this file to .env and replace placeholder values.

# Public runtime variables (Expo)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
EXPO_PUBLIC_LOCATIONIQ_API_KEY=your_locationiq_api_key

# Private administrative variables (never expose in app code)
SUPABASE_PROJECT_ID=your_supabase_project_id
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ACCESS_TOKEN=your_supabase_management_access_token
